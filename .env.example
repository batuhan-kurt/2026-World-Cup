# =============================================================
# 2026 Dünya Kupası Dashboard — Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env.local olarak kaydedin
# .env.local dosyası GİT'E EKLENMEYECEKTİR (.gitignore'da)
# =============================================================

# --- API-Football (RapidAPI) ---
# RapidAPI'den alacağınız API anahtarınızı buraya yapıştırın
# https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# --- Mock Modu ---
# Gerçek API bağlanana kadar mock JSON verilerini kullanmak için "true" yapın
# API bağlantısı hazır olunca "false" yapın
USE_MOCK_DATA=true

# --- Turnuva Bilgileri ---
# 2026 FIFA Dünya Kupası League ID (API-Football'daki)
WC_LEAGUE_ID=1
WC_SEASON=2026

# --- Next.js Public Değişkenler (Tarayıcıda erişilebilir) ---
# Dikkat: NEXT_PUBLIC_ öneki ile başlayan değerler istemci tarafında görünür
NEXT_PUBLIC_APP_NAME=2026 Dünya Kupası Dashboard
NEXT_PUBLIC_REFRESH_INTERVAL=60000
